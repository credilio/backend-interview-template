{
  "name": "backend-interview-template",
  "version": "0.0.0",
  "description": "A clean template to be used during backend engineer's interview.",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run clean && tsgo -p tsconfig.build.json",
    "clean": "rimraf dist coverage",
    "commit": "git-cz",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "lint": "oxlint --type-aware .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "report": "npm run lint && npm run build && node dist/index.js",
    "test": "vitest",
    "test:watch": "npm run test -- --watch"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "sort-package-json": "^4.0.0",
    "vitest": "^4.1.9"
  }
}
